diff -Nbaur gcc-4.7.2/libcpp/Makefile.in gcc-4.7.2-sh4/libcpp/Makefile.in
--- gcc-4.7.2/libcpp/Makefile.in	2012-09-20 08:23:55.000000000 +0100
+++ gcc-4.7.2-sh4/libcpp/Makefile.in	2013-01-30 02:27:52.000000000 +0000
@@ -214,8 +214,7 @@
 # Note that we put the dependencies into a .Tpo file, then move them
 # into place if the compile succeeds.  We need this because gcc does
 # not atomically write the dependency output file.
-COMPILE = $(COMPILE.base) -o $@ -MT $@ -MMD -MP -MF $(DEPDIR)/$*.Tpo
-POSTCOMPILE = @mv $(DEPDIR)/$*.Tpo $(DEPDIR)/$*.Po
+COMPILE = $(COMPILE.base) -o $@
 else
 COMPILE = source='$<' object='$@' libtool=no DEPDIR=$(DEPDIR) $(DEPMODE) \
 	  $(depcomp) $(COMPILE.base)
